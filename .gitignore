# ============================================================================
# SportsAction Deep Learning Project - Git Ignore Rules
# ============================================================================

# Data directories - large datasets should not be committed
# Ignore entire data/ directory including raw video files, extracted frames, and annotations
data/

# Model weights - PyTorch checkpoints
# Ignore .pth and .pt files at all depths in experiments/
# NOTE: .json log files (e.g., training_log.json) are NOT ignored - they will be tracked
experiments/**/*.pth
experiments/**/*.pt
experiments/**/*.pkl
experiments/**/*.h5
experiments/**/*.ckpt

# Virtual environments - do not commit environment folders
.venv/
venv/
env/

# Python artifacts and cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# IDE and editor configurations
.vscode/
.idea/
*.swp
*.swo
*~

# OS-specific files
.DS_Store
Thumbs.db

# Local logs and runtime files
logs/
*.log
failed_files.log

# Jupyter Notebook
.ipynb_checkpoints/

# Miscellaneous
.env
*.bak
temp/
tmp/
*.zip
*.tar.gz
*.rar
_corrupted_backup/